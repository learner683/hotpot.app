name: Manual Update Hotspot

on:
  workflow_dispatch:   # 允许手动触发

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'
      - name: Install dependencies
        run: pip install -r requirements.txt
      - name: Run pipeline
        env:
          DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
          ZHIHU_COOKIE: ${{ secrets.ZHIHU_COOKIE }}
        run: python pipeline.py
      - name: Commit and push updated data files
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add final_reports.json all_hot.json events.json deep_search_results.json 2>/dev/null || true
          git diff --staged --quiet || (git commit -m "Auto update data" && git push)
